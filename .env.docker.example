# =====================================================================
# Docker Compose 环境变量模板
# 用法：
#   cp .env.docker.example .env
#   按需修改 .env 中的值
# 注意：.env 已在 .gitignore 中，不会被提交
# =====================================================================

# ---- 前端端口（宿主机监听）----
FRONTEND_PORT=80

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=please-change-this-strong-password
MYSQL_DATABASE=abaojie

# ---- JWT ----
JWT_SECRET=please-change-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# ---- Claude ----
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2048

# ---- 飞书（可选）----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_FAQ_APP_TOKEN=
FEISHU_FAQ_TABLE_ID=
FEISHU_DOC_APP_TOKEN=
FEISHU_DOC_TABLE_ID=

# ---- 知识库 ----
KNOWLEDGE_EMBEDDING_PROVIDER=openai
KNOWLEDGE_EMBEDDING_MODEL=
KNOWLEDGE_GIT_REPO_URL=
KNOWLEDGE_GIT_BRANCH=main
